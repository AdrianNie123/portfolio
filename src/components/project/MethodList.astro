<div class="method-list">
  <slot />
</div>

<style>
  .method-list :global(ul) { list-style: none; padding: 0; margin: 2rem 0; }
  .method-list :global(li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-text-primary);
  }
  .method-list :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .method-list :global(li:last-child) { margin-bottom: 0; }
</style>
