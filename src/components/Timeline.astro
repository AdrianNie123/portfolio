---
import timeline from '../data/timeline.json';
---

<div class="relative mt-12">
  {/* Horizontal line */}
  <div class="absolute top-[5px] left-0 right-0 h-[2px] bg-border hidden md:block"></div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-4">
    {timeline.map((item) => (
      <div class="relative flex flex-col items-center text-center group">
        {/* Dot */}
        <div class="w-3 h-3 rounded-full bg-primary ring-4 ring-primary-light z-10 transition-transform duration-300 group-hover:scale-125"></div>

        {/* Content */}
        <div class="mt-4">
          <p class="text-sm font-semibold text-text-primary">{item.year}</p>
          <p class="text-sm font-medium text-primary mt-1">{item.title}</p>
          <p class="text-xs text-text-muted mt-0.5 italic">{item.organization}</p>
        </div>
      </div>
    ))}
  </div>
</div>
