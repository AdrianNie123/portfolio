---
import SocialCircles from './SocialCircles.astro';
---

<footer id="contact" class="portfolio-section bg-dark text-white py-16 px-6">
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="font-sans text-2xl font-medium mb-4">Get in Touch</h2>
    <p class="text-white/60 text-base max-w-md mx-auto mb-6 leading-relaxed">
      Open to collaborations in data research, visualization, and creative projects.
    </p>
    <a
      href="mailto:adriannie21@gmail.com"
      class="text-primary text-lg font-medium hover:underline transition-all"
    >
      adriannie21@gmail.com
    </a>
    <div class="mt-6 flex justify-center">
      <SocialCircles
        github="https://github.com/AdrianNie123"
        linkedin="https://www.linkedin.com/in/adrian-q-nie"
        dark={true}
      />
    </div>
    <p class="mt-10 text-white/30 text-xs tracking-wide">
      &copy; 2026 Adrian Nie
    </p>
  </div>
</footer>
